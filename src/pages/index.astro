---
import Layout from '../layouts/Layout.astro';
import HeroAnimado from '../components/HeroAnimado';
import Highlights from '../components/Highlights.astro';
import Amenidades from '../components/Amenidades.astro';
import Galeria from '../components/Galeria.astro';
import Experiencia from '../components/Experiencia.astro';
import Ubicacion from '../components/Ubicacion.astro';
import Resenas from '../components/Resenas.astro';
import FAQ from '../components/FAQ.astro';
import ContactoCTA from '../components/ContactoCTA.astro';
---

<Layout>
  <main>
    <HeroAnimado client:load />
    <Highlights />
    <Amenidades />
    <Galeria />
    <Experiencia />
    <Ubicacion />
    <Resenas />
    <FAQ />
    <ContactoCTA />
  </main>
</Layout>
