---
// Reemplazar con el embed real de Google Maps de tu propiedad
const mapEmbedUrl = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15058.123456789!2d-99.2319!3d18.6578!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85ce0000000000%3A0x0!2sTequesquitengo%2C+Morelos!5e0!3m2!1ses!2smx!4v0000000000000';
---

<section id="ubicacion" class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-14">
      <p class="text-teal-600 font-semibold tracking-widest text-sm uppercase mb-3">¿Cómo llegar?</p>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900" style="font-family: 'Playfair Display', serif;">
        Ubicación
      </h2>
      <p class="mt-4 text-gray-500 text-lg">
        Tequesquitengo, Morelos, México
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-10 items-center">

      <!-- Info de cómo llegar -->
      <div class="space-y-6">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center text-2xl">🚗</div>
          <div>
            <h3 class="font-semibold text-gray-800 mb-1">Desde Ciudad de México</h3>
            <p class="text-gray-500">Aproximadamente 2 horas por la autopista México-Cuernavaca. Salida en [indicación específica].</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center text-2xl">🚌</div>
          <div>
            <h3 class="font-semibold text-gray-800 mb-1">En autobús</h3>
            <p class="text-gray-500">Salidas frecuentes desde la Central del Sur CDMX. Puedes tomar taxi del centro de Jojutla hasta Tequesquitengo.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center text-2xl">📍</div>
          <div>
            <h3 class="font-semibold text-gray-800 mb-1">Dirección exacta</h3>
            <p class="text-gray-500">[Dirección completa]. Se comparte por WhatsApp al confirmar la reserva.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center text-2xl">🌡️</div>
          <div>
            <h3 class="font-semibold text-gray-800 mb-1">Clima</h3>
            <p class="text-gray-500">Cálido todo el año, promedio 28-32°C. Temporada de lluvias: junio a septiembre.</p>
          </div>
        </div>
      </div>

      <!-- Mapa -->
      <div class="rounded-2xl overflow-hidden shadow-xl h-80">
        <!-- Placeholder hasta tener el embed real -->
        <div class="w-full h-full bg-gradient-to-br from-teal-200 to-blue-300 flex items-center justify-center">
          <div class="text-center text-teal-800">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-3 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
            <p class="font-semibold opacity-70">Tequesquitengo, Morelos</p>
            <p class="text-sm opacity-50 mt-1">Reemplazar con Google Maps embed</p>
          </div>
        </div>
        <!-- Descomentar cuando tengas el embed real:
        <iframe
          src={mapEmbedUrl}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación Casa Tequesquitengo en Google Maps"
        ></iframe>
        -->
      </div>

    </div>
  </div>
</section>
