---
const stats = [
  { icon: '👥', value: '10', label: 'Huéspedes' },
  { icon: '🛏️', value: '3', label: 'Habitaciones' },
  { icon: '🚿', value: '2', label: 'Baños' },
  { icon: '📍', value: '2h', label: 'desde CDMX' },
];
---

<section id="highlights" class="py-16 bg-teal-700">
  <div class="max-w-5xl mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center text-white">
      {stats.map((s) => (
        <div class="flex flex-col items-center gap-2">
          <span class="text-4xl">{s.icon}</span>
          <span class="text-4xl font-bold">{s.value}</span>
          <span class="text-teal-200 font-medium">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
