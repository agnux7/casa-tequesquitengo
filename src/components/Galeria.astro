---
// Reemplazar los src con tus fotos reales. Formato recomendado: WebP, mín 1200px de ancho.
const fotos = [
  { src: '/images/foto-exterior.jpg', alt: 'Vista exterior de la casa con jardín y alberca en Tequesquitengo' },
  { src: '/images/foto-alberca.jpg', alt: 'Alberca privada con vista al jardín' },
  { src: '/images/foto-sala.jpg', alt: 'Sala de estar amplia y luminosa' },
  { src: '/images/foto-cocina.jpg', alt: 'Cocina totalmente equipada' },
  { src: '/images/foto-recamara.jpg', alt: 'Recámara principal con cama king' },
  { src: '/images/foto-lago.jpg', alt: 'Acceso al lago de Tequesquitengo' },
];
---

<section id="galeria" class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-14">
      <p class="text-teal-600 font-semibold tracking-widest text-sm uppercase mb-3">Fotos</p>
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900" style="font-family: 'Playfair Display', serif;">
        La Casa
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {fotos.map((foto, i) => (
        <div
          class={`overflow-hidden rounded-2xl bg-teal-100 ${i === 0 ? 'sm:col-span-2 sm:row-span-2' : ''}`}
          style={`aspect-ratio: ${i === 0 ? '4/3' : '4/3'};`}
        >
          <!-- Placeholder visual hasta tener fotos reales -->
          <div class="w-full h-full min-h-[220px] bg-gradient-to-br from-teal-200 to-emerald-300 flex items-center justify-center">
            <div class="text-center text-teal-700">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <p class="text-sm font-medium opacity-60">{foto.alt}</p>
            </div>
          </div>
          <!-- Descomentar cuando tengas fotos reales:
          <img
            src={foto.src}
            alt={foto.alt}
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
          -->
        </div>
      ))}
    </div>
  </div>
</section>
