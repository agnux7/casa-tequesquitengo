---
const airbnbUrl = 'https://airbnb.com/rooms/TU_ID_AQUI';
---

<section class="relative h-screen min-h-[600px] flex items-center justify-center overflow-hidden">
  <!-- Imagen de fondo placeholder -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-teal-900 via-teal-700 to-emerald-600"
    aria-hidden="true"
  >
    <!-- Reemplazar este div con una etiqueta <img> con tu foto real -->
    <div class="absolute inset-0 bg-black/40"></div>
    <!-- Patrón decorativo de agua -->
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.4\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')"
    >
    </div>
  </div>

  <!-- Contenido -->
  <div class="relative z-10 text-center text-white px-4 max-w-4xl mx-auto">
    <p class="text-amber-300 font-semibold tracking-widest text-sm uppercase mb-4">
      Tequesquitengo, Morelos · México
    </p>
    <h1
      class="text-5xl md:text-7xl font-bold mb-6 leading-tight"
      style="font-family: 'Playfair Display', serif;"
    >
      Casa <span class="text-amber-300">[Nombre de la Casa]</span>
    </h1>
    <p class="text-xl md:text-2xl text-white/90 mb-10 max-w-2xl mx-auto leading-relaxed">
      Tu refugio perfecto a orillas del lago. Descansa, relájate y crea recuerdos
      inolvidables en Tequesquitengo.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={airbnbUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-amber-400 hover:bg-amber-300 text-gray-900 font-bold px-8 py-4 rounded-full text-lg transition-all duration-200 shadow-xl hover:shadow-2xl hover:-translate-y-0.5"
      >
        Ver disponibilidad
      </a>
      <a
        href="#amenidades"
        class="border-2 border-white/70 hover:border-white text-white font-semibold px-8 py-4 rounded-full text-lg transition-all duration-200 hover:bg-white/10"
      >
        Conocer la casa
      </a>
    </div>
  </div>

  <!-- Flecha scroll -->
  <a
    href="#highlights"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/60 hover:text-white transition-colors animate-bounce"
    aria-label="Ver más"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </a>
</section>
